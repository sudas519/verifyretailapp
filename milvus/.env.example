# Milvus Configuration
# Copy this file to .env if you need to customize settings

# Milvus Connection
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=Milvus
MILVUS_COLLECTION=product_insights

# Milvus Security
MILVUS_SECURE=false

# Collection Schema
MILVUS_DENSE_FIELD=vector
MILVUS_TEXT_FIELD=text

# Embedding Configuration (for verification)
EMBEDDING_DIM=1024

# Docker Volume Directory (optional)
# Leave empty to use current directory
DOCKER_VOLUME_DIRECTORY=